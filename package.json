{
    "name": "sveltekit",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "prettier --check . && eslint .",
        "format": "prettier --write .",
        "test": "vitest",
        "test:unit": "vitest --project unit",
        "test:integration": "vitest --project integration",
        "test:run": "vitest run",
        "test:core": "vitest run --config vitest.core.config.ts",
        "test:packages": "vitest run --config vitest.core.config.ts",
        "test:scripts": "vitest run tests/scripts",
        "ramps:validate-manifest": "tsx scripts/validate-manifest.ts",
        "ramps:validate-catalog": "tsx scripts/validate-catalog.ts",
        "ramps:test": "tsx scripts/test-conformance.ts",
        "ramps:scaffold": "tsx scripts/scaffold-provider.ts"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.1",
        "@eslint/js": "^9.39.2",
        "@sveltejs/adapter-auto": "^7.0.0",
        "@sveltejs/adapter-vercel": "^6.3.3",
        "@sveltejs/kit": "^2.50.1",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.1.18",
        "@types/node": "^24",
        "@vitest/browser-playwright": "^4.0.18",
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.14.0",
        "globals": "^17.1.0",
        "msw": "^2.12.10",
        "playwright": "^1.58.1",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.4.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "svelte": "^5.48.2",
        "svelte-check": "^4.3.5",
        "tailwindcss": "^4.1.18",
        "tsx": "^4.19.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.53.1",
        "vite": "^7.3.1",
        "vitest": "^4.0.18",
        "vitest-browser-svelte": "^2.0.2"
    },
    "dependencies": {
        "@stellar-ramps/core": "workspace:*",
        "@stellar/freighter-api": "^6.0.1",
        "@stellar/stellar-sdk": "^14.5.0"
    },
    "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316"
}
